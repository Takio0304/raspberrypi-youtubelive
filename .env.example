# YouTubeのストリームキー
STREAM_KEY="xxxx-xxxx-xxxx-xxxx"

# マイクのデバイス番号 (arecord -l で確認)
AUDIO_DEVICE="hw:3,0"

# カメラデバイス (省略時: /dev/video0)
# VIDEO_DEVICE="/dev/video2"

# 解像度を固定する場合に指定 (省略時: 自動検出)
# VIDEO_SIZE="1280x720"

# 配信の定期再起動間隔（秒）。省略時: 再起動なし
# 4時間 = 14400秒
# RESTART_INTERVAL="14400"

# YouTube Data API v3 キー (チャット監視による録画機能を使う場合に設定)
# https://console.cloud.google.com/ で取得
# YOUTUBE_API_KEY="AIza..."

# YouTubeライブ配信のURL
# コメントで「rec」と送ると直近20分の録画を保存
# YOUTUBE_VIDEO_URL="https://www.youtube.com/watch?v=XXXXX"
